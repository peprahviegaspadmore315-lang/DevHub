# ===========================================
# Learning Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============ Database ============
# Local example:
# DB_URL=jdbc:postgresql://localhost:5432/learning_platform
#
# Supabase production example:
# DB_URL=jdbc:postgresql://aws-0-example.pooler.supabase.com:5432/postgres
DB_URL=jdbc:postgresql://localhost:5432/learning_platform
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# ============ JWT Security ============
# Generate a strong random secret (at least 256 bits)
JWT_SECRET=your_super_secret_jwt_key_at_least_256_bits_long_here

# ============ Frontend / CORS ============
# Comma-separated list of allowed origins
# Production example:
# CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
FRONTEND_BASE_URL=http://localhost:5174
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
PASSWORD_RESET_CODE_LENGTH=6
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-devhub-sender@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-devhub-sender@gmail.com
FEEDBACK_RECIPIENT=your-feedback-inbox@gmail.com

# ============ AI Configuration ============
# Choose provider: gemini or openai
AI_ENABLED=true
AI_PROVIDER=gemini

# Gemini Configuration (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash

# OpenAI Configuration (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_URL=https://api.openai.com/v1/responses
AI_MODEL=gpt-5.4

# ============ Docker (Optional) ============
DOCKER_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock

# ============ Redis (Optional) ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

