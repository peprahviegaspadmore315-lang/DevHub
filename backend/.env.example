# ===========================================
# Learning Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============ Database ============
DB_URL=jdbc:postgresql://localhost:5432/learning_platform
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# ============ JWT Security ============
# Generate a strong random secret (at least 256 bits)
JWT_SECRET=your_super_secret_jwt_key_at_least_256_bits_long_here

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============ AI Configuration ============
# Choose provider: gemini or openai
AI_ENABLED=true
AI_PROVIDER=gemini

# Gemini Configuration (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-1.5-flash

# OpenAI Configuration (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# ============ Docker (Optional) ============
DOCKER_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock

# ============ Redis (Optional) ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
